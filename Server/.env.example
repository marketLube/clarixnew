# Server (copy to .env and fill in secrets)
NODE_ENV=development
PORT=5000

# MongoDB — include the database name in the path (e.g. .../Clarix)
MONGO_URI=

# Optional: matches the DB name segment in MONGO_URI (used for docs / tooling)
DB_NAME=Clarix

# DigitalOcean Spaces (S3-compatible)
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_REGION=sgp1
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=
DO_SPACES_BUCKET=

# Gmail / SMTP (optional — omit to log OTP to console instead)
SMTP_USER=
SMTP_PASS=
